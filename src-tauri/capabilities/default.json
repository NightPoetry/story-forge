{
  "identifier": "default",
  "description": "Default capabilities for Narrative Forge",
  "windows": ["main"],
  "webviews": ["main"],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "https://api.anthropic.com/*",
      "https://*.anthropic.com/*",
      "https://api.openai.com/*",
      "https://*"
    ]
  },
  "local": true,
  "permissions": [
    "core:default",
    "shell:allow-open",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",

    "fs:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http:**" }, { "url": "https:**" }]
    },
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-read-dir",

    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",

    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }]
    }
  ]
}
